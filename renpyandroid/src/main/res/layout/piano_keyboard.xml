<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#22000000"
    android:id="@+id/piano_keyboard_root">

    <!-- Keyboard Area (will be scaled) -->
    <FrameLayout
        android:id="@+id/piano_keyboard_area"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:transformPivotY="180dp"
        android:transformPivotX="0dp">

        <!-- White keys -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="12">

            <Button android:id="@+id/btn_white_q" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="Q" />
            <Button android:id="@+id/btn_white_w" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="W" />
            <Button android:id="@+id/btn_white_e" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="E" />
            <Button android:id="@+id/btn_white_r" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="R" />
            <Button android:id="@+id/btn_white_t" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="T" />
            <Button android:id="@+id/btn_white_y" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="Y" />
            <Button android:id="@+id/btn_white_u" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="U" />
            <Button android:id="@+id/btn_white_i" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="I" />
            <Button android:id="@+id/btn_white_o" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="O" />
            <Button android:id="@+id/btn_white_p" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="P" />
            <Button android:id="@+id/btn_white_lbracket" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="1dp" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="[" />
            <Button android:id="@+id/btn_white_rbracket" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:backgroundTint="#F0F0F0" android:textColor="#000000" android:text="]" />

        </LinearLayout>

        <!-- Black keys -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:weightSum="12">
            
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.7"/>
            <Button android:id="@+id/btn_black_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="2" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4"/>
            <Button android:id="@+id/btn_black_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="3" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4"/>
            <Button android:id="@+id/btn_black_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="4" />
            
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.4"/>
            
            <Button android:id="@+id/btn_black_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="6" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4"/>
            <Button android:id="@+id/btn_black_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="7" />
            
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.4"/>
            
            <Button android:id="@+id/btn_black_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="9" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4"/>
            <Button android:id="@+id/btn_black_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="0" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4"/>
            <Button android:id="@+id/btn_black_minus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:text="-" />
            
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.7"/>

        </LinearLayout>
    </FrameLayout>
    
    <!-- Settings Button -->
    <Button
        android:id="@+id/btn_piano_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:backgroundTint="#AA666666"
        android:textColor="#FFFFFF"
        android:text="@string/piano_settings"
        android:textStyle="bold" />

    <!-- Settings Overlay -->
    <LinearLayout
        android:id="@+id/piano_settings_area"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#DD222222"
        android:padding="24dp"
        android:visibility="gone">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/piano_size"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>
            
        <SeekBar
            android:id="@+id/piano_size_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:layout_marginBottom="16dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/piano_opacity"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>
            
        <SeekBar
            android:id="@+id/piano_opacity_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:layout_marginBottom="24dp"/>
            
        <Button
            android:id="@+id/btn_piano_close_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/piano_close"
            android:backgroundTint="#AA4444FF"
            android:textColor="#FFFFFF"/>
            
    </LinearLayout>
</FrameLayout>
